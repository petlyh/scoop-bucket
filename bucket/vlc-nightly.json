{
    "version": "4.0.0-20220413-0425-c8d2923e",
    "description": "A free and open source cross-platform multimedia player and framework that plays most multimedia files as well as DVDs, Audio CDs, VCDs, and various streaming protocols.",
    "homepage": "https://www.videolan.org/",
    "license": "GPL-2.0-only",
    "architecture": {
        "64bit": {
            "url": "https://artifacts.videolan.org/vlc/nightly-win64/20220413-0425/vlc-4.0.0-dev-win64-c8d2923e.7z",
            "hash": "sha512:83b461ea0bfa7fd612f1253c8f166f0f84196db89163d83ed8a007ec4c5be12a8771a65c8509ee913bd776e6833064fcf77d8eb2300a63c80dfa0ea9947f6754"
        }
    },
    "extract_dir": "vlc-4.0.0-dev",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\portable\") -and (Test-Path \"$env:APPDATA\\vlc\")) {",
        "    info \"Copying old '$env:APPDATA\\vlc' to '$persist_dir\\portable'\"",
        "    ensure \"$dir\\portable\\vlc\" | Out-Null",
        "    Copy-Item \"$env:APPDATA\\vlc\\*\" \"$dir\\portable\" -Recurse -Force",
        "    Move-Item \"$dir\\portable\\vlc-qt-interface.ini\" \"$dir\\portable\\vlc\"",
        "}"
    ],
    "bin": [
        [
            "vlc.exe",
            "vlc-nightly",
            "--no-qt-updates-notif"
        ]
    ],
    "shortcuts": [
        [
            "vlc.exe",
            "VLC media player (nightly)",
            "--no-qt-updates-notif"
        ]
    ],
    "persist": "portable",
    "checkver": {
        "url": "https://artifacts.videolan.org/vlc/nightly-win64/20220413-0425/",
        "regex": "win64/(?<timestamp>\\d{8}-\\d{4})/((.|\\n)*)vlc-(?<ver>\\d*?\\.\\d*?\\.\\d*?)-dev-win64-(?<commit>\\w{8}).exe",
        "replace": "${ver}-${timestamp}-${commit}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://artifacts.videolan.org/vlc/nightly-win64/$matchTimestamp/vlc-$matchVer-dev-win64-$matchCommit.7z"
            }
        },
        "hash": {
            "url": "$baseurl/SHA512SUM"
        },
        "extract_dir": "vlc-$matchVer-dev"
    }
}
